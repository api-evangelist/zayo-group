  "info": {
    "_postman_id": "3b4f37df-6673-46cb-a582-c5c6008fff7e",
    "name": "Zayo Group API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Zayo Group's developer API provides programmatic access to network discovery,\nquote and order, and service management capabilities for enterprise customers\nand partners. Requests are authenticated via OAuth 2.0 Client Credentials\ngrant, exchanging client credentials at the Zayo authorization server for a\nshort-lived (one-hour) Bearer access token that is then presented to the API\nendpoints. Endpoints derived from the public developer portal at\ndeveloper.zayo.com.\n\nContact Support:\n Name: Zayo Developer Portal",
      "type": "text/plain"
    }
